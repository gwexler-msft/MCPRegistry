@page "/"
@model IndexModel
@{
    ViewData["Title"] = "MCP Registry";
}

<h1>MCP Server Registry</h1>

<form method="get" class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" name="search" value="@Model.Search" placeholder="Search servers..." />
            <button type="submit" class="btn btn-primary">Search</button>
            <a class="btn btn-outline-secondary" asp-page="/Index">Clear</a>
        </div>
    </div>
    @if (Model.IsAdmin)
    {
        <div class="col-md-6 text-end">
            <a class="btn btn-success" asp-page="/Servers/Add">+ Add Server</a>
        </div>
    }
</form>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.SuccessMessage is not null)
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (Model.Servers.Count == 0)
{
    <div class="alert alert-info">No servers found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Title</th>
                <th>Version</th>
                <th>Status</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Servers)
            {
                <tr class="@(item.IsDeleted ? "text-muted" : "")">
                    <td><code>@item.Server.Name</code></td>
                    <td>@(item.Server.Title ?? "—")</td>
                    <td><span class="badge bg-primary">@item.Server.Version</span></td>
                    <td>
                        @if (item.IsDeleted)
                        {
                            <span class="badge bg-secondary">deleted</span>
                        }
                        else
                        {
                            <span class="badge bg-success">active</span>
                        }
                    </td>
                    <td>@IndexModel.TruncateText(item.Server.Description, 80)</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Servers/Versions" asp-route-serverName="@item.Server.Name">Versions</a>
                        @if (!item.IsDeleted && Model.IsAdmin)
                        {
                            <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Delete @item.Server.Name @item.Server.Version?');">
                                <input type="hidden" name="serverName" value="@item.Server.Name" />
                                <input type="hidden" name="version" value="@item.Server.Version" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">@Model.Servers.Count server(s) shown</p>
}

