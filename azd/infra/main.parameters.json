{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": { "value": "${AZURE_ENV_NAME}" },
    "location": { "value": "${AZURE_LOCATION}" },
    "principalId": { "value": "${AZURE_PRINCIPAL_ID}" },
    "principalName": { "value": "${AZURE_PRINCIPAL_NAME}" },
    "workloadName": { "value": "${AZURE_WORKLOAD_NAME=mcpreg}" },
    "resourceGroupName": { "value": "${AZURE_RESOURCE_GROUP_NAME=}" },
    "logAnalyticsWorkspaceName": { "value": "${AZURE_LOG_ANALYTICS_NAME=}" },
    "containerRegistryName": { "value": "${AZURE_CONTAINER_REGISTRY_NAME=}" },
    "managedIdentityName": { "value": "${AZURE_MANAGED_IDENTITY_NAME=}" },
    "containerAppsEnvironmentName": { "value": "${AZURE_CONTAINER_APPS_ENV_NAME=}" },
    "sqlServerName": { "value": "${AZURE_SQL_SERVER_NAME=}" },
    "sqlDatabaseName": { "value": "${AZURE_SQL_DATABASE_NAME=MCPRegistry}" },
    "containerAppName": { "value": "${AZURE_CONTAINER_APP_NAME=}" },
    "vnetName": { "value": "${AZURE_VNET_NAME=}" },
    "vnetAddressPrefix": { "value": "${AZURE_VNET_ADDRESS_PREFIX=10.100.0.0/16}" },
    "acaSubnetPrefix": { "value": "${AZURE_ACA_SUBNET_PREFIX=10.100.0.0/23}" },
    "peSubnetPrefix": { "value": "${AZURE_PE_SUBNET_PREFIX=10.100.2.0/24}" },
    "peerVnetResourceId": { "value": "${AZURE_PEER_VNET_RESOURCE_ID=}" },
    "hubVnetResourceId": { "value": "${AZURE_HUB_VNET_RESOURCE_ID=}" },
    "dnsZoneLinkVnetResourceIdsCsv": { "value": "${AZURE_DNS_ZONE_LINK_VNET_RESOURCE_IDS=}" },
    "extraAllowedSourceCidrsCsv": { "value": "${AZURE_EXTRA_ALLOWED_SOURCE_CIDRS=}" },
    "apiContainerImage": { "value": "${SERVICE_API_IMAGE_NAME=mcr.microsoft.com/azuredocs/containerapps-helloworld:latest}" },
    "uiContainerImage": { "value": "${SERVICE_UI_IMAGE_NAME=mcr.microsoft.com/azuredocs/containerapps-helloworld:latest}" },
    "deployBastion": { "value": "${AZURE_DEPLOY_BASTION=false}" },
    "bastionSubnetPrefix": { "value": "${AZURE_BASTION_SUBNET_PREFIX=10.100.20.0/26}" },
    "bastionName": { "value": "${AZURE_BASTION_NAME=}" },
    "bastionPublicIpName": { "value": "${AZURE_BASTION_PUBLIC_IP_NAME=}" },
    "deployDevVm": { "value": "${AZURE_DEPLOY_DEV_VM=false}" },
    "devSubnetPrefix": { "value": "${AZURE_DEV_SUBNET_PREFIX=10.100.4.0/27}" },
    "devVmSize": { "value": "${AZURE_DEV_VM_SIZE=Standard_B2s}" },
    "devVmAdminUsername": { "value": "${AZURE_DEV_VM_ADMIN_USERNAME=azureuser}" },
    "devVmAdminPassword": { "value": "${AZURE_DEV_VM_ADMIN_PASSWORD=}" },
    "devVmShutdownTime": { "value": "${AZURE_DEV_VM_SHUTDOWN_TIME=1900}" },
    "devVmShutdownTimezone": { "value": "${AZURE_DEV_VM_SHUTDOWN_TZ=Central Standard Time}" },
    "tenantId": { "value": "${AZURE_TENANT_ID}" },
    "apiAppClientId": { "value": "${AZURE_API_APP_CLIENT_ID}" },
    "uiAppClientId": { "value": "${AZURE_UI_APP_CLIENT_ID}" },
    "uiAppClientSecret": { "value": "${AZURE_UI_APP_CLIENT_SECRET}" },
    "adminGroupId": { "value": "${AZURE_ADMIN_GROUP_ID}" },
    "aspnetEnvironment": { "value": "${aspnetEnvironment=Production}" }
  }
}
